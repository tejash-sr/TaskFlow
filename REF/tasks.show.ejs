<!-- App Header -->
<div class="app-header">
  <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle Sidebar">
    <i class="fas fa-bars"></i>
  </button>
  <div class="app-header-content">
    <div>
      <a href="/tasks" class="back-link" style="margin-bottom:var(--space-1);">
        <i class="fas fa-arrow-left"></i> Back to Tasks
      </a>
      <h1 class="page-title"><%= task.title %></h1>
    </div>
    <div class="app-header-actions">
      <span class="status-pill status-<%= task.status.replace('-','') %>"><%= task.status %></span>
      <span class="badge badge-<%= task.priority %>"><%= task.priority %></span>
    </div>
  </div>
</div>

<script>
function toggleDescEdit() {
  var display = document.getElementById('desc-display');
  var form = document.getElementById('desc-edit-form');
  var btn = document.getElementById('desc-edit-btn');
  var isEditing = form.style.display !== 'none';
  display.style.display = isEditing ? '' : 'none';
  form.style.display = isEditing ? 'none' : '';
  btn.innerHTML = isEditing
    ? '<i class="fas fa-edit"></i> Edit'
    : '<i class="fas fa-times"></i> Cancel';
}

function updateStatusColor(sel) {
  var colors = { 'todo': '#94a3b8', 'in-progress': '#f59e0b', 'review': '#6366f1', 'done': '#10b981' };
  var c = colors[sel.value] || '#94a3b8';
  sel.style.borderColor = c;
  sel.style.boxShadow = '0 0 0 3px ' + c + '33';
}

function updateFileName(input) {
  const MAX_SIZE = 5 * 1024 * 1024; // 5MB
  const ALLOWED_TYPES = ['application/pdf', 'image/png', 'image/jpeg', 'image/gif', 'image/webp',
    'application/msword', 'application/vnd.openxmlformats-officedocument.wordprocessingml.document'];
  const label = document.getElementById('fileName-' + input.id.replace('fileInput-', ''));
  const area  = input.closest('label')?.querySelector('.file-upload-area');
  const errEl = document.getElementById('fileErr-' + input.id.replace('fileInput-', ''));
  const btn   = document.getElementById('uploadBtn-' + input.id.replace('fileInput-', ''));

  if (!input.files.length) return;
  const file = input.files[0];

  if (file.size > MAX_SIZE) {
    if (area)  { area.classList.add('error'); area.classList.remove('has-file'); }
    if (errEl) { errEl.textContent = `File too large (${(file.size/1024/1024).toFixed(1)} MB). Maximum is 5 MB.`; errEl.classList.add('visible'); }
    if (label) label.textContent = 'Choose a file to upload';
    if (btn)   btn.disabled = true;
    input.value = '';
    return;
  }
  if (!ALLOWED_TYPES.includes(file.type)) {
    if (area)  { area.classList.add('error'); area.classList.remove('has-file'); }
    if (errEl) { errEl.textContent = 'Invalid file type. Allowed: PDF, PNG, JPG, GIF, WEBP, DOC, DOCX'; errEl.classList.add('visible'); }
    if (label) label.textContent = 'Choose a file to upload';
    if (btn)   btn.disabled = true;
    input.value = '';
    return;
  }

  // Valid file
  if (area)  { area.classList.remove('error'); area.classList.add('has-file'); }
  if (errEl) { errEl.textContent = ''; errEl.classList.remove('visible'); }
  if (label) label.textContent = file.name + ' (' + (file.size/1024).toFixed(1) + ' KB)';
  if (btn)   btn.disabled = false;
}

// Initialise status colour on page load
(function() {
  var sel = document.getElementById('statusSelect');
  if (sel) updateStatusColor(sel);
})();
</script>
<div class="task-detail-layout">
  <!-- Main Content -->
  <div class="task-detail-main">
    <div class="task-detail-header">
      <div class="task-detail-status-row">
        <span class="status-pill status-<%= task.status.replace('-','') %>"><%= task.status %></span>
        <span class="badge badge-<%= task.priority %>"><%= task.priority %></span>
      </div>
      <h2 class="task-detail-title"><%= task.title %></h2>
      <div class="task-detail-meta">
        <% if (task.assignee) { %>
          <span><i class="fas fa-user"></i> <%= task.assignee.name || 'Unassigned' %></span>
        <% } %>
        <% if (task.project) { %>
          <span><i class="fas fa-folder"></i> <%= task.project.name || task.project %></span>
        <% } %>
        <% if (task.dueDate) { %>
          <span><i class="fas fa-calendar-alt"></i> Due <%= new Date(task.dueDate).toLocaleDateString() %></span>
        <% } %>
        <span><i class="fas fa-clock"></i> Created <%= new Date(task.createdAt).toLocaleDateString() %></span>
      </div>
    </div>

    <!-- Description -->
    <div class="task-detail-description">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:var(--space-3);">
        <h3 style="margin:0;"><i class="fas fa-align-left"></i> Description</h3>
        <button type="button" class="btn btn-ghost btn-sm" onclick="toggleDescEdit()" id="desc-edit-btn">
          <i class="fas fa-edit"></i> Edit
        </button>
      </div>
      <!-- Display mode -->
      <div class="description-content" id="desc-display">
        <% if (task.description) { %>
          <%= task.description %>
        <% } else { %>
          <em style="color:var(--text-tertiary);">No description provided.</em>
        <% } %>
      </div>
      <!-- Edit mode -->
      <form action="/tasks/<%= task._id %>/update" method="POST" id="desc-edit-form" style="display:none;">
        <textarea name="description" class="form-input" rows="5"
          style="resize:vertical;margin-bottom:var(--space-3);"><%= task.description || '' %></textarea>
        <div style="display:flex;gap:var(--space-2);">
          <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-save"></i> Save</button>
          <button type="button" class="btn btn-ghost btn-sm" onclick="toggleDescEdit()">Cancel</button>
        </div>
      </form>
    </div>

    <!-- Tags -->
    <% if (task.tags && task.tags.length > 0) { %>
      <div class="task-detail-section">
        <h3><i class="fas fa-tags"></i> Tags</h3>
        <div class="tag-list">
          <% task.tags.forEach(function(tag) { %>
            <span class="tag"><%= tag %></span>
          <% }); %>
        </div>
      </div>
    <% } %>

    <!-- Comments -->
    <div class="task-detail-section">
      <h3><i class="fas fa-comments"></i> Comments (<%= comments.length %>)</h3>

      <div class="comment-form">
        <div class="avatar avatar-sm">
          <i class="fas fa-user" style="font-size:0.8rem;"></i>
        </div>
        <div class="comment-input-wrapper">
          <form action="/tasks/<%= task._id %>/comments" method="POST">
            <textarea name="body" class="form-input" rows="3" placeholder="Write a comment&hellip;" required></textarea>
            <div class="comment-form-actions">
              <button type="submit" class="btn btn-primary btn-sm">
                <i class="fas fa-paper-plane"></i> Post Comment
              </button>
            </div>
          </form>
        </div>
      </div>

      <% if (comments.length === 0) { %>
        <div class="empty-state" style="padding:var(--space-8) 0;">
          <i class="fas fa-comments" style="font-size:2rem;"></i>
          <p>No comments yet. Be the first!</p>
        </div>
      <% } else { %>
        <div class="comments-list">
          <% comments.forEach(function(comment) { %>
            <div class="comment" id="comment-<%= comment._id %>">
              <div class="avatar avatar-sm">
                <%= comment.author ? comment.author.name.charAt(0).toUpperCase() : '?' %>
              </div>
              <div class="comment-body">
                <div class="comment-header">
                  <strong><%= comment.author ? comment.author.name : 'Unknown' %></strong>
                  <span class="comment-time"><%= new Date(comment.createdAt).toLocaleString() %></span>
                  <button type="button" class="btn-icon btn-xs text-danger"
                    style="opacity:0.6;margin-left:auto;"
                    onclick="openConfirmModal('del-comment-<%= comment._id %>', 'Delete this comment? This cannot be undone.')"
                    title="Delete comment">
                    <i class="fas fa-trash"></i>
                  </button>
                  <form id="del-comment-<%= comment._id %>" action="/comments/<%= comment._id %>/delete" method="POST" style="display:none;">
                    <input type="hidden" name="taskId" value="<%= task._id %>" />
                  </form>
                </div>
                <p><%= comment.content %></p>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="task-detail-sidebar">
    <!-- Update Status -->
    <div class="task-sidebar-card">
      <h4><i class="fas fa-edit"></i> Update Status</h4>
      <form action="/tasks/<%= task._id %>/status" method="POST">
        <div class="form-group">
          <div class="status-select-wrapper" id="statusSelectWrapper">
            <select name="status" class="form-select status-select" id="statusSelect"
              onchange="updateStatusColor(this)">
              <option value="todo" <%= task.status === 'todo' ? 'selected' : '' %>>⬜ To Do</option>
              <option value="in-progress" <%= task.status === 'in-progress' ? 'selected' : '' %>>🔄 In Progress</option>
              <option value="review" <%= task.status === 'review' ? 'selected' : '' %>>🔍 In Review</option>
              <option value="done" <%= task.status === 'done' ? 'selected' : '' %>>✅ Done</option>
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-sm">
          <i class="fas fa-sync-alt"></i> Update Status
        </button>
      </form>
    </div>

    <!-- Task Details -->
    <div class="task-sidebar-card">
      <h4><i class="fas fa-info-circle"></i> Details</h4>
      <div class="task-sidebar-details">
        <div class="detail-row">
          <span class="detail-label">Status</span>
          <span class="detail-value">
            <span class="status-pill status-<%= task.status.replace('-','') %>" style="font-size:0.7rem;">
              <%= task.status %>
            </span>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Priority</span>
          <span class="detail-value">
            <span class="badge badge-<%= task.priority %>"><%= task.priority %></span>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Assignee</span>
          <span class="detail-value">
            <% if (task.assignee) { %>
              <div class="avatar avatar-xs"><%= task.assignee.name.charAt(0).toUpperCase() %></div>
              <%= task.assignee.name %>
            <% } else { %>
              <span style="color:var(--text-tertiary);">Unassigned</span>
            <% } %>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Project</span>
          <span class="detail-value">
            <% if (task.project) { %>
              <i class="fas fa-folder" style="color:var(--color-primary);"></i>
              <%= task.project.name || task.project %>
            <% } else { %>
              <span style="color:var(--text-tertiary);">None</span>
            <% } %>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Due Date</span>
          <span class="detail-value">
            <% if (task.dueDate) { %>
              <i class="fas fa-calendar-alt" style="color:var(--color-primary);"></i>
              <%= new Date(task.dueDate).toLocaleDateString() %>
            <% } else { %>
              <span style="color:var(--text-tertiary);">Not set</span>
            <% } %>
          </span>
        </div>
        <div class="detail-row">
          <span class="detail-label">Created</span>
          <span class="detail-value" style="font-size:0.8rem;color:var(--text-secondary);">
            <%= new Date(task.createdAt).toLocaleDateString() %>
          </span>
        </div>
      </div>
    </div>

    <!-- Attachments -->
    <div class="task-sidebar-card">
      <h4><i class="fas fa-paperclip"></i> Attachments</h4>
      <!-- BUG-10 fix: show existing attachments with download links -->
      <% if (task.attachments && task.attachments.length > 0) { %>
        <ul style="list-style:none;padding:0;margin:0 0 var(--space-3) 0;">
          <% task.attachments.forEach(function(att) { %>
            <li style="display:flex;align-items:center;justify-content:space-between;padding:var(--space-2) 0;border-bottom:1px solid var(--border-color);">
              <span style="font-size:0.85rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:140px;" title="<%= att.filename %>">
                <i class="fas fa-file" style="margin-right:4px;color:var(--text-tertiary);"></i><%= att.filename %>
              </span>
              <a href="/api/tasks/<%= task._id %>/attachments/<%= att._id %>"
                 class="btn btn-secondary btn-sm"
                 style="flex-shrink:0;padding:2px 8px;font-size:0.75rem;"
                 download="<%= att.filename %>">
                <i class="fas fa-download"></i>
              </a>
            </li>
          <% }); %>
        </ul>
      <% } %>
      <form action="/tasks/<%= task._id %>/attachments" method="POST" enctype="multipart/form-data">
        <div class="form-group">
          <label class="file-upload-label">
            <input type="file" name="file" id="fileInput-<%= task._id %>"
              style="display:none;"
              accept=".pdf,.png,.jpg,.jpeg,.gif,.webp,.doc,.docx"
              onchange="updateFileName(this)" />
            <div class="file-upload-area" onclick="document.getElementById('fileInput-<%= task._id %>').click()">
              <i class="fas fa-cloud-upload-alt"></i>
              <div id="fileName-<%= task._id %>" class="file-upload-msg">Choose a file to upload</div>
            </div>
          </label>
          <div id="fileErr-<%= task._id %>" class="file-error-msg"></div>
          <div class="file-upload-msg" style="margin-top:4px;">Max 5 MB — PDF, PNG, JPG, GIF, DOCX</div>
        </div>
        <button type="submit" id="uploadBtn-<%= task._id %>" class="btn btn-secondary btn-block btn-sm">
          <i class="fas fa-upload"></i> Upload File
        </button>
      </form>
    </div>

    <!-- Actions -->
    <div class="task-sidebar-card">
      <h4><i class="fas fa-cog"></i> Actions</h4>
      <div class="task-sidebar-actions">
        <a href="/tasks/new" class="btn btn-secondary btn-sm btn-block">
          <i class="fas fa-plus"></i> New Task
        </a>
        <form action="/tasks/<%= task._id %>/delete" method="POST" id="deleteTaskForm">
          <button type="button" class="btn btn-danger-outline btn-sm btn-block" onclick="openConfirmModal('deleteTaskForm', 'Delete this task permanently? This cannot be undone.')">
            <i class="fas fa-trash"></i> Delete Task
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
