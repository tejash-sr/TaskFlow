+    if (title && title.trim()) update.title = title.trim();
+    if (description !== undefined) update.description = description.trim();
+    await taskService.update(req.params.id, update);
+  } catch {
+    // ignore
+  }
+  res.redirect('/tasks/' + req.params.id);
