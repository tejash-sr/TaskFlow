+import Task from '@/models/Task.model';
+import { AppError } from '@/utils/AppError';
+import { Types } from 'mongoose';
+
+jest.mock('@/models/Task.model');
+jest.mock('@/queues/emailQueue', () => ({
+  enqueueEmail: jest.fn().mockResolvedValue(undefined),
+}));
+
+const MockedTask = Task as jest.Mocked<typeof Task>;
+
+describe('Digest Service', () => {
+  beforeEach(() => {
+    jest.clearAllMocks();
+  });
+
+  describe('getUsersWithOverdueTasks', () => {
+    it('aggregates overdue tasks per user', async () => {
+      const userId1 = new Types.ObjectId();
+      const userId2 = new Types.ObjectId();
+      const overdueTasks = [
+        { assignee: { _id: userId1, name: 'Alice', email: 'alice@test.com' } },
+        { assignee: { _id: userId1, name: 'Alice', email: 'alice@test.com' } },
+        { assignee: { _id: userId2, name: 'Bob', email: 'bob@test.com' } },
+        { assignee: null }, // should be skipped
+      ];
+
+      (MockedTask.find as jest.Mock).mockReturnValue({
+        populate: jest.fn().mockResolvedValue(overdueTasks),
+      });
+
+      const { getUsersWithOverdueTasks } = await import('@/services/digest.service');
+      const result = await getUsersWithOverdueTasks();
+
+      expect(result).toHaveLength(2);
+      const alice = result.find((e) => e.name === 'Alice');
+      expect(alice?.overdueCount).toBe(2);
+      const bob = result.find((e) => e.name === 'Bob');
+      expect(bob?.overdueCount).toBe(1);
+    });
+
+    it('returns empty array when no overdue tasks', async () => {
+      (MockedTask.find as jest.Mock).mockReturnValue({
+        populate: jest.fn().mockResolvedValue([]),
+      });
+
+      const { getUsersWithOverdueTasks } = await import('@/services/digest.service');
+      const result = await getUsersWithOverdueTasks();
+      expect(result).toHaveLength(0);
+    });
+  });
+
+  describe('runDailyDigest', () => {
+    it('enqueues emails for each user with overdue tasks', async () => {
+      const userId = new Types.ObjectId();
+      const overdueTasks = [
+        { assignee: { _id: userId, name: 'Alice', email: 'alice@test.com' } },
+      ];
+      (MockedTask.find as jest.Mock).mockReturnValue({
+        populate: jest.fn().mockResolvedValue(overdueTasks),
+      });
+
+      const { runDailyDigest } = await import('@/services/digest.service');
+      const { enqueueEmail } = await import('@/queues/emailQueue');
+
+      const result = await runDailyDigest();
+      expect(result).toHaveLength(1);
+      expect(enqueueEmail).toHaveBeenCalledWith(
+        expect.objectContaining({
+          type: 'dailyDigest',
+          to: 'alice@test.com',
+          name: 'Alice',
+          overdueCount: 1,
+        }),
+      );
+    });
+
+    it('returns empty array and sends no emails when no overdue tasks', async () => {
+      (MockedTask.find as jest.Mock).mockReturnValue({
+        populate: jest.fn().mockResolvedValue([]),
+      });
+
+      const { runDailyDigest } = await import('@/services/digest.service');
+      const { enqueueEmail } = await import('@/queues/emailQueue');
+
+      const result = await runDailyDigest();
+      expect(result).toHaveLength(0);
+      expect(enqueueEmail).not.toHaveBeenCalled();
+    });
+  });
+});
