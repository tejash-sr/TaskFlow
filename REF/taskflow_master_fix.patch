diff --git a/tests/unit/middleware/auth.middleware.test.ts b/tests/unit/middleware/auth.middleware.test.ts
new file mode 100644
index 0000000..a6be5bf
--- /dev/null
+++ b/tests/unit/middleware/auth.middleware.test.ts
@@ -0,0 +1,118 @@
+import { Request, Response, NextFunction } from 'express';
+import { isAuth, isAdmin, isOwnerOrAdmin } from '@/middleware/auth.middleware';
+import { signAccessToken } from '@/utils/tokenUtils';
+import { Types } from 'mongoose';
+
+// Mock the blacklist check to always return false (not blacklisted) in tests
+jest.mock('@/utils/tokenBlacklist', () => ({
+  isTokenBlacklisted: jest.fn().mockResolvedValue(false),
+  blacklistToken: jest.fn().mockResolvedValue(undefined),
+}));
+
+function makeReq(overrides: Partial<Request> = {}): Request {
+  return { headers: {}, ...overrides } as unknown as Request;
+}
+
+function makeRes(): Response {
+  return {} as Response;
+}
+
+function makeNext(): jest.Mock {
+  return jest.fn();
+}
+
+describe('Auth Middleware', () => {
+  describe('isAuth', () => {
+    it('calls next with 401 when no Authorization header', async () => {
+      const req = makeReq();
+      const next = makeNext();
+      isAuth(req, makeRes(), next);
+      // Wait for async blacklist check
+      await new Promise((r) => setTimeout(r, 10));
+      expect(next).toHaveBeenCalledWith(expect.objectContaining({ statusCode: 401 }));
+    });
+
+    it('calls next with 401 when header does not start with Bearer', async () => {
+      const req = makeReq({ headers: { authorization: 'Basic abc123' } });
+      const next = makeNext();
+      isAuth(req, makeRes(), next);
+      await new Promise((r) => setTimeout(r, 10));
+      expect(next).toHaveBeenCalledWith(expect.objectContaining({ statusCode: 401 }));
+    });
+
+    it('calls next with 401 when token is invalid', async () => {
+      const req = makeReq({ headers: { authorization: 'Bearer bad.token.here' } });
+      const next = makeNext();
+      isAuth(req, makeRes(), next);
+      await new Promise((r) => setTimeout(r, 10));
+      expect(next).toHaveBeenCalled();
+    });
+
+    it('sets req.userId and calls next() for valid token', async () => {
+      const userId = new Types.ObjectId().toString();
+      const token = signAccessToken({ userId, role: 'user' });
+      const req = makeReq({ headers: { authorization: `Bearer ${token}` } });
+      const next = makeNext();
+      isAuth(req, makeRes(), next);
+      await new Promise((r) => setTimeout(r, 50));
+      expect((req as unknown as { userId: string }).userId).toBe(userId);
+      expect(next).toHaveBeenCalledWith(); // no error argument
+    });
+  });
+
+  describe('isAdmin', () => {
+    it('calls next with 403 when user is not admin', () => {
+      const req = makeReq({ userRole: 'user' } as Partial<Request>);
+      const next = makeNext();
+      isAdmin(req, makeRes(), next);
+      expect(next).toHaveBeenCalledWith(expect.objectContaining({ statusCode: 403 }));
+    });
+
+    it('calls next() when user is admin', () => {
+      const req = makeReq({ userRole: 'admin' } as Partial<Request>);
+      const next = makeNext();
+      isAdmin(req, makeRes(), next);
+      expect(next).toHaveBeenCalledWith(); // no args
+    });
+  });
+
+  describe('isOwnerOrAdmin', () => {
+    it('calls next() immediately when user is admin', async () => {
+      const req = makeReq({ userRole: 'admin', userId: 'admin-id' } as Partial<Request>);
+      const next = makeNext();
+      const middleware = isOwnerOrAdmin(() => 'other-user-id');
+      middleware(req, makeRes(), next);
+      await new Promise((r) => setTimeout(r, 10));
+      expect(next).toHaveBeenCalledWith();
+    });
+
+    it('calls next(403) when user is not owner', async () => {
+      const req = makeReq({ userRole: 'user', userId: 'user-id' } as Partial<Request>);
+      const next = makeNext();
+      const middleware = isOwnerOrAdmin(() => 'other-owner-id');
+      middleware(req, makeRes(), next);
+      await new Promise((r) => setTimeout(r, 10));
+      expect(next).toHaveBeenCalledWith(expect.objectContaining({ statusCode: 403 }));
+    });
+
+    it('calls next() when user is the owner', async () => {
+      const userId = 'same-user-id';
+      const req = makeReq({ userRole: 'user', userId } as Partial<Request>);
+      const next = makeNext();
+      const middleware = isOwnerOrAdmin(() => userId);
+      middleware(req, makeRes(), next);
+      await new Promise((r) => setTimeout(r, 10));
+      expect(next).toHaveBeenCalledWith();
+    });
+
+    it('handles async owner resolver', async () => {
+      const userId = 'async-user-id';
+      const req = makeReq({ userRole: 'user', userId } as Partial<Request>);
+      const next = makeNext();
+      const middleware = isOwnerOrAdmin(async () => userId);
+      middleware(req, makeRes(), next);
+      await new Promise((r) => setTimeout(r, 50));
+      expect(next).toHaveBeenCalledWith();
+    });
+  });
+});
