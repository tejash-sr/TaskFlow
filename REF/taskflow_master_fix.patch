+import { CommentService } from '@/services/comment.service';
+import Comment from '@/models/Comment.model';
+import Task from '@/models/Task.model';
+import { AppError } from '@/utils/AppError';
+import { Types } from 'mongoose';
+
+jest.mock('@/models/Comment.model');
+jest.mock('@/models/Task.model');
+jest.mock('@/models/User.model');
+jest.mock('@/queues/emailQueue', () => ({
+  enqueueEmail: jest.fn().mockResolvedValue(undefined),
+}));
+
+const MockedComment = Comment as jest.Mocked<typeof Comment>;
+const MockedTask = Task as jest.Mocked<typeof Task>;
+
+describe('CommentService', () => {
+  let service: CommentService;
+
+  beforeEach(() => {
+    service = new CommentService();
+    jest.clearAllMocks();
+  });
+
+  describe('create', () => {
+    it('throws 404 when task not found', async () => {
+      (MockedTask.findOne as jest.Mock).mockReturnValue({
+        populate: jest.fn().mockReturnThis(),
+        // second populate returns null (task not found)
+        then: undefined,
+      });
+      const chain = { populate: jest.fn().mockReturnThis() };
+      (MockedTask.findOne as jest.Mock).mockReturnValue(chain);
+      chain.populate
+        .mockReturnValueOnce(chain)
+        .mockResolvedValueOnce(null);
+
+      await expect(
+        service.create(new Types.ObjectId().toString(), 'userId', { content: 'hi' }),
+      ).rejects.toMatchObject({ statusCode: 404 });
+    });
+
+    it('creates a comment and returns it populated', async () => {
+      const taskId = new Types.ObjectId().toString();
+      const authorId = new Types.ObjectId().toString();
+      const assigneeId = new Types.ObjectId();
+
+      const mockTask = {
+        _id: taskId,
+        title: 'Test Task',
+        assignee: { _id: assigneeId, name: 'Assignee', email: 'a@test.com' },
+        project: { name: 'Project' },
+      };
+
+      const mockComment = {
+        _id: new Types.ObjectId(),
+        content: 'hi',
+        author: authorId,
+        task: taskId,
+        populate: jest.fn().mockResolvedValue({ content: 'hi' }),
+      };
+
+      const chain = { populate: jest.fn().mockReturnThis() };
+      (MockedTask.findOne as jest.Mock).mockReturnValue(chain);
+      chain.populate.mockReturnValueOnce(chain).mockResolvedValueOnce(mockTask);
+      (MockedComment.create as jest.Mock).mockResolvedValue(mockComment);
+
+      const result = await service.create(taskId, assigneeId.toString(), { content: 'hi' });
+      expect(MockedComment.create).toHaveBeenCalledWith(
+        expect.objectContaining({ content: 'hi', author: authorId || assigneeId.toString() }),
+      );
+    });
+  });
+
+  describe('deleteComment', () => {
+    it('throws 404 when comment not found', async () => {
+      (MockedComment.findById as jest.Mock).mockResolvedValue(null);
+      await expect(
+        service.deleteComment(new Types.ObjectId().toString(), 'userId'),
+      ).rejects.toMatchObject({ statusCode: 404 });
+    });
+
+    it('throws 403 when requester is not the author', async () => {
+      const comment = {
+        _id: new Types.ObjectId(),
+        author: new Types.ObjectId(),
+        toString: () => 'other-user-id',
+      };
+      comment.author = { toString: () => 'other-user-id' } as unknown as Types.ObjectId;
+      (MockedComment.findById as jest.Mock).mockResolvedValue(comment);
+
+      await expect(
+        service.deleteComment(comment._id.toString(), 'requester-id'),
+      ).rejects.toMatchObject({ statusCode: 403 });
+    });
+
+    it('deletes the comment successfully', async () => {
+      const userId = new Types.ObjectId().toString();
+      const comment = {
+        _id: new Types.ObjectId(),
+        author: { toString: () => userId },
+      };
+      (MockedComment.findById as jest.Mock).mockResolvedValue(comment);
+      (MockedComment.findByIdAndDelete as jest.Mock).mockResolvedValue(comment);
+
+      await expect(
+        service.deleteComment(comment._id.toString(), userId),
+      ).resolves.not.toThrow();
+      expect(MockedComment.findByIdAndDelete).toHaveBeenCalledWith(comment._id.toString());
+    });
+  });
+
+  describe('findByTask', () => {
+    it('throws 404 when task not found', async () => {
+      (MockedTask.findOne as jest.Mock).mockResolvedValue(null);
+      await expect(
+        service.findByTask(new Types.ObjectId().toString()),
+      ).rejects.toMatchObject({ statusCode: 404 });
+    });
+
+    it('returns comments sorted by creation date', async () => {
+      const taskId = new Types.ObjectId().toString();
+      (MockedTask.findOne as jest.Mock).mockResolvedValue({ _id: taskId });
+      const comments = [{ content: 'first' }, { content: 'second' }];
+      (MockedComment.find as jest.Mock).mockReturnValue({
+        populate: jest.fn().mockReturnThis(),
+        sort: jest.fn().mockResolvedValue(comments),
+      });
+
+      const result = await service.findByTask(taskId);
+      expect(result).toEqual(comments);
+    });
+  });
+});
