<div class="auth-container auth-container-centered">
  <div class="auth-form-wrapper">
    <div class="auth-form-container auth-form-narrow">
      <div class="auth-brand">
        <a href="/">
          <div class="brand-icon brand-icon-sm"><i class="fas fa-bolt"></i></div>
          <span class="brand-text">Task<span class="brand-accent">Flow</span></span>
        </a>
      </div>

      <div class="auth-icon-circle">
        <i class="fas fa-envelope"></i>
      </div>

      <h1 class="auth-title">Resend Verification</h1>
      <p class="auth-subtitle">Enter your email to receive a new verification link</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-error">
          <i class="fas fa-exclamation-circle"></i> <%= error %>
        </div>
      <% } %>
      <% if (typeof message !== 'undefined' && message) { %>
        <div class="alert alert-success">
          <i class="fas fa-check-circle"></i> <%= message %>
        </div>
      <% } %>

      <div class="auth-form">
        <form action="/resend-verification" method="POST">
          <div class="form-group">
            <label class="form-label" for="email">Email address</label>
            <div class="input-wrapper">
              <i class="fas fa-envelope input-icon"></i>
              <input type="email" id="email" name="email" class="form-input"
                placeholder="you@example.com" required autocomplete="email" />
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-block">
            <i class="fas fa-paper-plane"></i> Send Verification Email
          </button>
        </form>
      </div>

      <p class="auth-footer-text">
        <a href="/login"><i class="fas fa-arrow-left"></i> Back to Sign In</a>
      </p>
    </div>
  </div>
</div>
