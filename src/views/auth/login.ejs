<div class="auth-container">
    <!-- Left visual panel -->
    <div class="auth-visual">
      <div class="auth-visual-shapes">
        <div class="auth-shape auth-shape-1"></div>
        <div class="auth-shape auth-shape-2"></div>
        <div class="auth-shape auth-shape-3"></div>
      </div>
      <div class="auth-visual-content">
        <div class="auth-visual-text">
          <h2>Welcome Back</h2>
          <p>Sign in to manage your tasks, track projects, and keep your team in sync — all in one place.</p>
        </div>
        <div class="auth-visual-features">
          <div class="auth-feature">
            <i class="fas fa-check-circle"></i>
            <span>Real-time task updates via Socket.io</span>
          </div>
          <div class="auth-feature">
            <i class="fas fa-check-circle"></i>
            <span>REST &amp; GraphQL API access</span>
          </div>
          <div class="auth-feature">
            <i class="fas fa-check-circle"></i>
            <span>PDF &amp; CSV report exports</span>
          </div>
          <div class="auth-feature">
            <i class="fas fa-check-circle"></i>
            <span>JWT-secured, end-to-end encrypted</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Right form panel -->
    <div class="auth-form-wrapper">
      <div class="auth-form-container">
        <div class="auth-brand">
          <a href="/">
            <div class="brand-icon brand-icon-sm"><i class="fas fa-bolt"></i></div>
            <span class="brand-text">Task<span class="brand-accent">Flow</span></span>
          </a>
        </div>

        <h1 class="auth-title">Sign in to your account</h1>
        <p class="auth-subtitle">Enter your credentials to continue</p>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="alert alert-error">
            <i class="fas fa-exclamation-circle"></i>
            <%= error %>
          </div>
        <% } %>

        <div class="auth-form">
          <form action="/login" method="POST">
            <div class="form-group">
              <label class="form-label" for="email">Email address</label>
              <div class="input-wrapper">
                <i class="fas fa-envelope input-icon"></i>
                <input
                  type="email" id="email" name="email" class="form-input"
                  placeholder="you@example.com"
                  value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
                  required autocomplete="email"
                />
              </div>
            </div>
            <div class="form-group">
              <div class="form-label-row">
                <label class="form-label" for="password">Password</label>
                <a href="/forgot-password" class="form-link">Forgot password?</a>
              </div>
              <div class="input-wrapper">
                <i class="fas fa-lock input-icon"></i>
                <input
                  type="password" id="password" name="password" class="form-input"
                  placeholder="Enter your password"
                  required autocomplete="current-password"
                />
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-block">
              <i class="fas fa-sign-in-alt"></i> Sign In
            </button>
          </form>
        </div>

        <p class="auth-footer-text">
          Don&rsquo;t have an account? <a href="/signup">Create one free</a>
        </p>
      </div>
    </div>
  </div>
