<!-- App Header -->
<div class="app-header">
  <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle Sidebar">
    <i class="fas fa-bars"></i>
  </button>
  <div class="app-header-content">
    <div>
      <h1 class="page-title"><i class="fas fa-user-circle"></i> My Profile</h1>
    </div>
  </div>
</div>

<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'error' %>" style="margin:0 var(--space-5) var(--space-4);">
    <i class="fas fa-<%= flash.type === 'success' ? 'check-circle' : 'exclamation-circle' %>"></i>
    <%= flash.message %>
  </div>
<% } %>

<div style="padding: var(--space-5);">
  <div class="profile-layout">

    <!-- Left: Avatar Card -->
    <div>
      <div class="profile-card">
        <div class="avatar-section">
          <% if (user.avatar) { %>
            <img src="/<%= user.avatar %>" alt="Avatar" class="avatar-large" id="avatarPreview" />
          <% } else { %>
            <div class="avatar-large-initials" id="avatarInitials">
              <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
            </div>
          <% } %>

          <p style="font-size:1.1rem;font-weight:700;margin:0 0 4px;"><%= user.name %></p>
          <p style="font-size:0.85rem;color:var(--text-secondary);margin:0 0 var(--space-3);">
            <i class="fas fa-envelope"></i> <%= user.email %>
          </p>
          <span class="badge badge-<%= user.role === 'admin' ? 'urgent' : 'low' %>">
            <i class="fas fa-<%= user.role === 'admin' ? 'shield-alt' : 'user' %>"></i> <%= user.role %>
          </span>

          <!-- Avatar Upload -->
          <div class="avatar-upload-actions" style="margin-top:var(--space-4);">
            <label for="avatarInput" class="btn btn-secondary btn-sm" style="cursor:pointer;">
              <i class="fas fa-camera"></i> Change Photo
            </label>
            <input type="file" id="avatarInput" accept="image/jpeg,image/png,image/gif,image/webp"
              style="display:none;" onchange="previewAndUploadAvatar(this)" />
            <% if (user.avatar) { %>
              <button type="button" class="btn btn-ghost btn-sm" style="color:var(--color-danger);"
                onclick="removeAvatar()">
                <i class="fas fa-trash"></i> Remove
              </button>
            <% } %>
          </div>
          <p class="avatar-hint">JPG, PNG, GIF or WEBP &middot; Max 2 MB &middot; Resized to 200&times;200</p>
        </div>

        <!-- Account Info -->
        <div>
          <p class="profile-section-title"><i class="fas fa-info-circle"></i> Account Info</p>
          <div style="display:flex;flex-direction:column;gap:var(--space-3);">
            <div>
              <span style="font-size:0.75rem;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.06em;">Member Since</span>
              <p style="margin:2px 0;font-weight:500;"><%= new Date(user.createdAt).toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) %></p>
            </div>
            <div>
              <span style="font-size:0.75rem;color:var(--text-tertiary);text-transform:uppercase;letter-spacing:.06em;">Email Verified</span>
              <p style="margin:2px 0;">
                <% if (user.emailVerified) { %>
                  <span style="color:var(--color-success);"><i class="fas fa-check-circle"></i> Verified</span>
                <% } else { %>
                  <span style="color:var(--color-danger);"><i class="fas fa-times-circle"></i> Not Verified</span>
                  &mdash;
                  <a href="/resend-verification" style="font-size:0.85rem;">Resend email</a>
                <% } %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Right: Edit Profile Card -->
    <div>
      <div class="profile-card">
        <p class="profile-section-title"><i class="fas fa-edit"></i> Edit Profile</p>

        <form action="/profile/update" method="POST" id="profileForm">
          <div class="form-group">
            <label class="form-label" for="name">Full Name</label>
            <input type="text" id="name" name="name" class="form-input"
              value="<%= user.name %>" required minlength="2" maxlength="50" />
          </div>

          <div class="form-group">
            <label class="form-label" for="email">Email Address</label>
            <input type="email" id="email" name="email" class="form-input"
              value="<%= user.email %>" required autocomplete="email" />
          </div>

          <button type="submit" class="btn btn-primary">
            <i class="fas fa-save"></i> Save Changes
          </button>
        </form>

        <!-- Change Password -->
        <div style="margin-top:var(--space-6);padding-top:var(--space-5);border-top:1px solid var(--border-color);">
          <p class="profile-section-title"><i class="fas fa-lock"></i> Change Password</p>
          <p style="font-size:0.875rem;color:var(--text-secondary);margin-bottom:var(--space-4);">
            Use the <a href="/forgot-password">forgot password</a> flow to securely reset your password via email.
          </p>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
const TOKEN_KEY = 'tf_token';

// Read JWT from cookie helper
function getToken() {
  const cookies = document.cookie.split(';');
  for (const c of cookies) {
    const [k, v] = c.trim().split('=');
    if (k === 'tf_token') return decodeURIComponent(v || '');
  }
  return '';
}

async function previewAndUploadAvatar(input) {
  const file = input.files[0];
  if (!file) return;

  const MAX = 2 * 1024 * 1024;
  if (file.size > MAX) {
    alert('Image must be smaller than 2 MB.');
    input.value = '';
    return;
  }
  if (!file.type.startsWith('image/')) {
    alert('Please select an image file.');
    input.value = '';
    return;
  }

  // Preview immediately
  const reader = new FileReader();
  reader.onload = (e) => {
    const prev = document.getElementById('avatarPreview');
    const init = document.getElementById('avatarInitials');
    if (prev) { prev.src = e.target.result; }
    else if (init) {
      const img = document.createElement('img');
      img.src = e.target.result;
      img.id = 'avatarPreview';
      img.className = 'avatar-large';
      img.alt = 'Avatar';
      init.replaceWith(img);
    }
  };
  reader.readAsDataURL(file);

  // Upload
  const formData = new FormData();
  formData.append('avatar', file);

  try {
    // BUG-03 fix: use web route with cookie auth — httpOnly cookie is sent automatically
    const res = await fetch('/profile/avatar', {
      method: 'POST',
      body: formData,
      credentials: 'same-origin',
    });
    const data = await res.json().catch(() => ({}));
    if (res.ok) {
      showToast('Profile picture updated!', 'success');
    } else {
      showToast(data['message'] || 'Upload failed', 'error');
    }
  } catch {
    showToast('Network error uploading avatar', 'error');
  }
}

async function removeAvatar() {
  if (!confirm('Remove your profile picture?')) return;
  try {
    // BUG-03 fix: use web route with cookie auth
    const res = await fetch('/profile/avatar', {
      method: 'DELETE',
      credentials: 'same-origin',
    });
    if (res.ok) {
      const prev = document.getElementById('avatarPreview');
      if (prev) {
        const initials = document.createElement('div');
        initials.id = 'avatarInitials';
        initials.className = 'avatar-large-initials';
        initials.textContent = '<%= user.name ? user.name.charAt(0).toUpperCase() : "U" %>';
        prev.replaceWith(initials);
      }
      showToast('Profile picture removed', 'success');
      // Hide remove button
      const removeBtn = document.querySelector('button[onclick="removeAvatar()"]');
      if (removeBtn) removeBtn.style.display = 'none';
    } else {
      const data = await res.json();
      showToast(data.message || 'Delete failed', 'error');
    }
  } catch {
    showToast('Network error', 'error');
  }
}

function showToast(msg, type) {
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  t.innerHTML = `<span class="toast-icon"><i class="fas fa-${type === 'success' ? 'check-circle' : 'exclamation-circle'}"></i></span><span class="toast-message">${msg}</span>`;
  t.style.cssText = 'position:fixed;bottom:1.5rem;right:1.5rem;z-index:9999;display:flex;align-items:center;gap:0.75rem;padding:0.85rem 1.25rem;background:var(--bg-primary);border:1px solid var(--border-color);border-radius:0.75rem;box-shadow:0 4px 24px rgba(0,0,0,.15);';
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 3500);
}
</script>
